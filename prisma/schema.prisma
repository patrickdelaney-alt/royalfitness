generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  name           String?
  username       String   @unique
  email          String   @unique
  passwordHash   String?
  bio            String?  @default("")
  avatarUrl      String?
  isPrivate      Boolean  @default(false)
  instagramUrl   String?
  tiktokUrl      String?
  onboardingStep String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  posts          Post[]
  comments       Comment[]
  likes          Like[]

  followers      Follow[]  @relation("following")
  following      Follow[]  @relation("follower")
  followRequestsReceived FollowRequest[] @relation("followRequestTarget")
  followRequestsSent     FollowRequest[] @relation("followRequestSender")

  gymMemberships GymMembership[]

  savedMeals       SavedMeal[]
  savedWorkouts    SavedWorkout[]
  supplements      Supplement[]
  wellnessAccessories WellnessAccessory[]
  savedWellness    SavedWellness[]
  affiliateItems   AffiliateItem[]

  stepsEntries   StepsEntry[]
  achievements   UserAchievement[]
  userStats      UserStats?

  notificationsReceived Notification[] @relation("notificationsReceived")
  notificationsActed    Notification[] @relation("notificationsActed")

  referralLinks        ReferralLink[]
  referralAttribution  ReferralAttribution? @relation("referralAttribution")

  notifyOnLike    Boolean @default(true)
  notifyOnComment Boolean @default(true)
  notifyOnFollow  Boolean @default(true)

  foundingMember     Boolean @default(false)
  foundingMemberSeen Boolean @default(false)

  reportsMade    Report[]      @relation("reporter")
  blockedUsers   BlockedUser[] @relation("blocker")
  blockedBy      BlockedUser[] @relation("blocked")

  accounts       Account[]
  sessions       Session[]

  foundingMemberInvites FoundingMemberInvite[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── SOCIAL ──────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model FollowRequest {
  id        String   @id @default(cuid())
  senderId  String
  targetId  String
  createdAt DateTime @default(now())

  sender User @relation("followRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  target User @relation("followRequestTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([senderId, targetId])
}

// ─── POSTS ───────────────────────────────────────────────────────

enum PostType {
  WORKOUT
  MEAL
  WELLNESS
  GENERAL
  CHECKIN
  AFFILIATE
  CATALOG_SHARE
}

enum CatalogItemType {
  MEAL
  WORKOUT
  SUPPLEMENT
  ACCESSORY
  WELLNESS
  AFFILIATE
}

enum Visibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

enum PostTiming {
  BEFORE
  DURING
  AFTER
}

model Post {
  id          String     @id @default(cuid())
  type        PostType
  caption     String?
  mediaUrl    String?
  visibility  Visibility @default(PUBLIC)
  tags        String[]   @default([])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  gymId       String?
  gym         Gym?       @relation(fields: [gymId], references: [id])

  workoutDetail      WorkoutDetail?
  mealDetail         MealDetail?
  wellnessDetail     WellnessDetail?
  affiliateDetail    AffiliateDetail?
  catalogShareDetail CatalogShareDetail?

  comments    Comment[]
  likes       Like[]
  externalContent ExternalContent[]
  notifications   Notification[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model WorkoutDetail {
  id                String    @id @default(cuid())
  postId            String    @unique
  post              Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  workoutName       String
  isClass           Boolean   @default(false)
  muscleGroups      String[]  @default([])
  durationMinutes   Int?
  perceivedExertion Int?
  moodAfter         Int?
  notes             String?
  postTiming        PostTiming @default(AFTER)

  exercises         Exercise[]
}

model Exercise {
  id              String        @id @default(cuid())
  workoutDetailId String
  workoutDetail   WorkoutDetail @relation(fields: [workoutDetailId], references: [id], onDelete: Cascade)

  name            String
  sortOrder       Int           @default(0)
  sets            ExerciseSet[]
}

model ExerciseSet {
  id         String   @id @default(cuid())
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  reps       Int?
  weight     Float?
  unit       String   @default("lbs")
  rpe        Int?
  sortOrder  Int      @default(0)
}

model MealDetail {
  id              String   @id @default(cuid())
  postId          String   @unique
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  mealName        String
  mealType        String   @default("snack")
  ingredients     String[] @default([])
  calories        Int?
  protein         Float?
  carbs           Float?
  fat             Float?
  recipeSourceUrl String?
  saveToCatalog   Boolean  @default(false)
}

model WellnessDetail {
  id              String @id @default(cuid())
  postId          String @unique
  post            Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  activityType    String
  durationMinutes Int?
  intensity       Int?
  moodAfter       Int?
  notes           String?
}

model AffiliateDetail {
  id              String            @id @default(cuid())
  postId          String            @unique
  post            Post              @relation(fields: [postId], references: [id], onDelete: Cascade)

  affiliateItemId String?
  title           String
  brand           String?
  link            String?
  referralCode    String?
  category        AffiliateCategory @default(OTHER)
}

// ─── EXTERNAL CONTENT ────────────────────────────────────────────

model ExternalContent {
  id          String  @id @default(cuid())
  postId      String
  post        Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  url         String
  title       String?
  description String?
  imageUrl    String?
  siteName    String?
  createdAt   DateTime @default(now())
}

// ─── COMMENTS & LIKES ────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt(sort: Desc)])
}

model Like {
  id       String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId   String
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

// ─── GYMS / GROUPS ───────────────────────────────────────────────

model Gym {
  id        String   @id @default(cuid())
  name      String
  address   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())

  members   GymMembership[]
  posts     Post[]
}

enum GymRole {
  MEMBER
  ADMIN
}

model GymMembership {
  id     String  @id @default(cuid())
  userId String
  gymId  String
  role   GymRole @default(MEMBER)
  joinedAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym    Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([userId, gymId])
}

// ─── CATALOGS ────────────────────────────────────────────────────

enum AffiliateCategory {
  SUPPLEMENTS
  WELLNESS_ACCESSORIES
  GYM_ACCESSORIES
  RECOVERY_TOOLS
  APPAREL
  NUTRITION
  TECH_WEARABLES
  OTHER
}

model SavedMeal {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  ingredients     String[] @default([])
  calories        Int?
  protein         Float?
  carbs           Float?
  fat             Float?
  recipeSourceUrl String?
  photoUrl        String?
  tags            String[] @default([])
  notes           String?
  isPrivate       Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model SavedWorkout {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  exercisesJson   String
  videoUrl        String?
  tags            String[] @default([])
  notes           String?
  isPrivate       Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Supplement {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  brand     String?
  dose      String?
  schedule  String?
  notes     String?
  photoUrl     String?
  link         String?
  referralCode String?
  tags         String[] @default([])
  isPrivate    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model WellnessAccessory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  type      String?
  link         String?
  photoUrl     String?
  referralCode String?
  tags         String[] @default([])
  notes        String?
  isPrivate    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model SavedWellness {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  activityType    String?
  durationMinutes Int?
  link            String?
  photoUrl        String?
  referralCode    String?
  tags            String[] @default([])
  notes           String?
  isPrivate       Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model AffiliateItem {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  brand        String?
  description  String?
  link         String?
  referralCode String?
  category     AffiliateCategory @default(OTHER)
  photoUrl     String?
  tags         String[]          @default([])
  isPrivate    Boolean           @default(false)
  createdAt    DateTime          @default(now())

  // Enrichment fields (additive, all optional/defaulted)
  subcategoryTags      String[]  @default([])
  ctaLabel             String?
  logoUrl              String?
  enrichmentConfidence String?
  needsReview          Boolean   @default(false)
}

// ─── CATALOG SHARE ───────────────────────────────────────────────

// Immutable snapshot of catalog item data captured at share time.
// Stays valid even if the source item is later edited or deleted.
model CatalogShareDetail {
  id              String          @id @default(cuid())
  postId          String          @unique
  post            Post            @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Source reference — not a foreign key because the item lives in one
  // of several different catalog tables (SavedMeal, AffiliateItem, etc.)
  catalogItemId   String
  catalogItemType CatalogItemType

  // Snapshot fields (immutable after creation)
  title           String
  brand           String?
  description     String?
  photoUrl        String?
  link            String?
  referralCode    String?
  category        String?        // AffiliateCategory value as string; null for non-affiliate types
  ctaLabel        String?        // e.g. "Shop Now", "Get Code"

  @@index([catalogItemId, catalogItemType])
}

// Anti-spam guard — one record per user per catalog item per calendar day.
// Unique constraint enforces the limit at the DB level.
// To switch to a rolling 24-hour window: query by createdAt >= now()-24h
// To add max-N-per-day: count records for userId+sharedDate and compare to a constant.
model CatalogShareCooldown {
  id              String          @id @default(cuid())
  userId          String
  catalogItemId   String
  catalogItemType CatalogItemType
  sharedDate      DateTime        @db.Date   // UTC calendar day only (no time)
  createdAt       DateTime        @default(now())

  @@unique([userId, catalogItemId, catalogItemType, sharedDate])
  @@index([userId, sharedDate])
}

// ─── ACHIEVEMENTS ────────────────────────────────────────────────

model UserAchievement {
  id        String   @id @default(cuid())
  userId    String
  badgeKey  String
  earnedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId])
}

model UserStats {
  userId           String    @id
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak    Int       @default(0)
  workoutStreak    Int       @default(0)
  streakComputedAt DateTime? // null = cache dirty, recompute on next stats read
}

// ─── STEPS ───────────────────────────────────────────────────────

model StepsEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      DateTime @db.Date
  count     Int
  source    String   @default("manual")
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

// ─── NOTIFICATIONS ──────────────────────────────────────────────

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  FOLLOW_REQUEST
  REFERRAL_PURCHASE
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  recipientId String
  recipient   User   @relation("notificationsReceived", fields: [recipientId], references: [id], onDelete: Cascade)

  // Nullable for REFERRAL_PURCHASE where the buyer is anonymous
  actorId String?
  actor   User?  @relation("notificationsActed", fields: [actorId], references: [id], onDelete: SetNull)

  postId String?
  post   Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)

  // REFERRAL_PURCHASE: human-readable copy e.g. "Someone used your AG1 link."
  body           String?
  referralLinkId String?
  referralLink   ReferralLink? @relation(fields: [referralLinkId], references: [id], onDelete: SetNull)

  @@index([recipientId, createdAt(sort: Desc)])
  @@index([recipientId, read])
}

// ─── MODERATION ──────────────────────────────────────────────────

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  postId     String?
  reason     String
  createdAt  DateTime @default(now())
}

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  blocker   User     @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

// ─── REFERRAL ────────────────────────────────────────────────────

// A unique shareable link tied to a post or catalog item.
// id doubles as the URL code: /r/<id>
model ReferralLink {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceType String   // 'post' | 'catalog_item'
  sourceId   String
  clickCount Int      @default(0)
  createdAt  DateTime @default(now())

  attributions  ReferralAttribution[]
  notifications Notification[]

  @@index([userId])
  @@index([sourceType, sourceId])
}

// Records which new user signed up via a referral link.
// One attribution per new user (enforced by unique on newUserId).
model ReferralAttribution {
  id             String       @id @default(cuid())
  referralLinkId String
  referralLink   ReferralLink @relation(fields: [referralLinkId], references: [id])
  newUserId      String       @unique
  newUser        User         @relation("referralAttribution", fields: [newUserId], references: [id])
  welcomeShown   Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

// ─── FOUNDING MEMBERS ────────────────────────────────────────────

model FoundingMemberInvite {
  id          String   @id @default(cuid())
  inviterId   String
  inviter     User     @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  token       String   @unique
  clickCount  Int      @default(0)
  signupCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([inviterId])
}

// ─── WAITLIST ─────────────────────────────────────────────────────

enum WaitlistStatus {
  PENDING
  APPROVED
  INVITED
  ACTIVATED
}

model WaitlistUser {
  id           String         @id @default(cuid())
  email        String         @unique
  firstName    String?
  status       WaitlistStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  approvedAt   DateTime?
  inviteSentAt DateTime?

  @@index([status])
  @@index([createdAt(sort: Desc)])
}
