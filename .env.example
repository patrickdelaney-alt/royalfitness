# PostgreSQL database URL
# Get a free one at https://neon.tech → New Project → copy the connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Random secret for session encryption (32+ chars)
# Generate one at https://generate-secret.vercel.app/32
# Auth.js v5 uses AUTH_SECRET (NEXTAUTH_SECRET also works as fallback)
AUTH_SECRET="replace-with-a-long-random-string"

# Your deployment URL (no trailing slash)
# Vercel Project: royalfitness
# On Vercel this is auto-detected as https://royalwellness.vercel.app
# For custom domains, set explicitly (e.g., https://royalwellness.app)
NEXTAUTH_URL="https://royalwellness.vercel.app"

# ── Apple Sign In (optional) ────────────────────────────────────────────────
# 1. Go to https://developer.apple.com → Certificates, Identifiers & Profiles
# 2. Create a Services ID (e.g. com.royalwellness.web) — this is APPLE_CLIENT_ID
# 3. Enable "Sign in with Apple", add your domain + return URL:
#      https://royalwellness.vercel.app/api/auth/callback/apple
# 4. Generate a private key, download it, and use it to sign a JWT → APPLE_CLIENT_SECRET
#    (Auth.js docs: https://authjs.dev/getting-started/providers/apple)
# APPLE_CLIENT_ID=com.yourapp.web
# APPLE_CLIENT_SECRET=<signed JWT>

# ── Google Sign In (optional) ───────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add authorised redirect URI:
#      https://royalwellness.vercel.app/api/auth/callback/google
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# ── Maintenance / Waitlist mode ──────────────────────────────────────────────
# Set to "true" to redirect all visitors to /waitlist (e.g. during downtime).
# Change in Vercel → Settings → Environment Variables, then redeploy.
MAINTENANCE_MODE=false

# ── Admin dashboard ──────────────────────────────────────────────────────────
# The email address that can access /admin to see new signups.
# Must match exactly the email used to log in.
ADMIN_EMAIL=

# ── Vercel Blob Storage (for photo/video uploads) ────────────────────────────
# Generate a token at https://vercel.com/account/storage/blob/tokens
# Required for photo and video uploads to work
BLOB_READ_WRITE_TOKEN=
