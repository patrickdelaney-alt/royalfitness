# PostgreSQL database URL
# Get a free one at https://neon.tech → New Project → copy the connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Random secret for session encryption (32+ chars)
# Generate one at https://generate-secret.vercel.app/32
# Auth.js v5 uses AUTH_SECRET (NEXTAUTH_SECRET also works as fallback)
AUTH_SECRET="replace-with-a-long-random-string"

# Your deployment URL (no trailing slash)
# Vercel Project: royalfitness
# On Vercel this is auto-detected as https://royalwellness.vercel.app
# For custom domains, set explicitly so password reset links use the right domain.
# Also aliased as AUTH_URL for Auth.js v5 compatibility.
NEXTAUTH_URL="https://royalwellness.app"

# ── Apple Sign In (REQUIRED for App Store — App Store Review §4.8) ──────────
# Apple mandates Sign in with Apple for any app that offers third-party login.
# If this app is distributed via the App Store, these variables MUST be set.
#
# Setup steps:
# 1. Apple Developer Portal → Certificates, Identifiers & Profiles
# 2. Identifiers → Register a new Services ID (e.g. com.royalwellness.web)
#    → this becomes APPLE_CLIENT_ID
# 3. Enable "Sign in with Apple" on the Services ID, add:
#      Domain:       royalwellness.app (or your custom domain)
#      Return URL:   https://royalwellness.app/api/auth/callback/apple
# 4. Keys → Register a new key, enable "Sign in with Apple", download the .p8 file
#    You'll need: Team ID, Key ID, and the .p8 key contents
# 5. Generate the client secret JWT (Auth.js docs: https://authjs.dev/getting-started/providers/apple)
#    The JWT is signed with your .p8 key and expires after 6 months — rotate it before then.
# APPLE_CLIENT_ID=com.royalwellness.web
# APPLE_CLIENT_SECRET=<signed JWT — regenerate every 6 months>

# ── Google Sign In (optional) ───────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add authorised redirect URI:
#      https://royalwellness.vercel.app/api/auth/callback/google
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# ── Maintenance / Waitlist mode ──────────────────────────────────────────────
# Set to "true" to redirect all visitors to /waitlist (e.g. during downtime).
# Change in Vercel → Settings → Environment Variables, then redeploy.
MAINTENANCE_MODE=false

# ── Waitlist gate ─────────────────────────────────────────────────────────────
# Set to "true" to restrict new signups to approved waitlist members only.
# Existing users (already in the User table) are never affected — they can always log in.
# Flip back to "false" (or remove) to open signups to everyone.
# Change in Vercel → Settings → Environment Variables, then redeploy.
WAITLIST_GATE_ENABLED=false

# ── Admin dashboard ──────────────────────────────────────────────────────────
# The email address that can access /admin to see new signups.
# Must match exactly the email used to log in.
ADMIN_EMAIL=

# ── Vercel Blob Storage (for photo/video uploads) ────────────────────────────
# Generate a token at https://vercel.com/account/storage/blob/tokens
# Required for photo and video uploads to work
BLOB_READ_WRITE_TOKEN=

# ── Email Service (Resend) ───────────────────────────────────────────────────
# Get your API key at https://resend.com → API Keys
# Used to send password reset and waitlist approval emails
# IMPORTANT: Without this key, password reset emails will fail with a 500 error.
# DNS: Ensure SPF is verified in Resend. Add a DMARC TXT record (_dmarc → v=DMARC1; p=none;)
# for better deliverability. MX records are only needed if receiving email at this domain.
RESEND_API_KEY=
